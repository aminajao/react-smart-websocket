{
  "name": "react-smart-websocket",
  "version": "1.0.0",
  "description": "Smart WebSocket hook for React with visibility-aware reconnection and multi-connection management",
  "main": "lib/index.js",
  "module": "lib/index.esm.js",
  "types": "lib/index.d.ts",
  "sideEffects": false,
  "files": [
    "lib",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run clean && rollup -c && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:watch": "rollup -c -w",
    "clean": "rm -rf lib",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "react",
    "websocket",
    "hooks",
    "real-time",
    "reconnection",
    "visibility",
    "typescript"
  ],
  "author": "Amin Ajao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aminajao/react-smart-websocket.git"
  },
  "homepage": "https://github.com/aminajao/react-smart-websocket#readme",
  "bugs": {
    "url": "https://github.com/aminajao/react-smart-websocket/issues"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rollup": "^4.49.0",
    "ts-jest": "^29.4.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
